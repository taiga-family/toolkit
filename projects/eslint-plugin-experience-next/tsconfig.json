{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "allowImportingTsExtensions": false,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "paths": {
            "typescript": ["../../node_modules/typescript/lib/typescript.d.ts"]
        }
    },
    "include": ["./*.ts", "**/*.d.ts"],
    "exclude": ["**/*.spec.ts"]
}
