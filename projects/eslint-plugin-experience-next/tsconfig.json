{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "allowImportingTsExtensions": false,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "tsBuildInfoFile": "/dev/null"
    },
    "include": ["./*.ts", "**/*.d.ts"],
    "exclude": ["**/*.spec.ts"]
}
