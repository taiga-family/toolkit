{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "name": "stylelint-config",
    "prefix": "tui",
    "projectType": "library",
    "sourceRoot": "projects/stylelint-config",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    "tsc -p {projectRoot}/tsconfig.json",
                    "cp {projectRoot}/README.md ./dist/{projectName}",
                    "cp {projectRoot}/package.json ./dist/{projectName}"
                ],
                "parallel": false
            },
            "outputs": ["{workspaceRoot}/dist/{projectName}"]
        },
        "publish": {
            "dependsOn": [
                {
                    "dependencies": false,
                    "params": "ignore",
                    "target": "build"
                }
            ],
            "executor": "nx:run-commands",
            "options": {
                "command": "npm publish ./dist/{projectName} --access=public --ignore-scripts"
            }
        }
    }
}
