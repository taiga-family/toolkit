{
    "name": "@taiga-ui/toolkit",
    "version": "0.548.0",
    "private": true,
    "license": "Apache-2.0",
    "workspaces": [
        "projects/*"
    ],
    "scripts": {
        "after:bump": "npx nx build syncer && node projects/syncer/bin/src/index.js",
        "cspell": "cspell --relative --dot --gitignore .",
        "lint": "eslint .",
        "prettier": "prettier !package-lock.json . --ignore-path .gitignore",
        "release": "npx nx run-many --target publish --all",
        "stylelint": "nx run stylelint-config:build && stylelint '**/*.{less,css}' --allow-empty-input --config package.json",
        "test": "jest ."
    },
    "commitlint": {
        "extends": [
            "./dist/commitlint-config"
        ]
    },
    "lint-staged": {
        "*.{js,ts,html,svg,yml,md,less,json}": [
            "prettier --write",
            "eslint --fix",
            "cspell"
        ]
    },
    "browserslist": [
        "extends @taiga-ui/browserslist-config"
    ],
    "prettier": "@taiga-ui/prettier-config",
    "stylelint": {
        "extends": [
            "./dist/stylelint-config/index.esm.js"
        ],
        "ignoreFiles": [
            "**/demo/**",
            "**/dist/**",
            "**/coverage/**",
            "**/node_modules/**"
        ]
    },
    "overrides": {
        "@angular/common": "19.2.25",
        "@angular/compiler": "19.2.25",
        "@angular/compiler-cli": "19.2.25",
        "@angular/core": "19.2.25",
        "@angular/platform-browser-dynamic": "19.2.25"
    },
    "devDependencies": {
        "@angular-devkit/core": "19.2.27",
        "@angular/cdk": "19.2.19",
        "@angular/cli": "19.2.27",
        "@angular/common": "19.2.25",
        "@angular/compiler": "19.2.25",
        "@angular/compiler-cli": "19.2.25",
        "@angular/core": "19.2.25",
        "@angular/platform-browser-dynamic": "19.2.25",
        "@nx/rollup": "22.7.5",
        "nx": "22.7.5",
        "ts-node": "10.9.2",
        "typescript": "5.8.3",
        "zone.js": "0.15.1"
    },
    "cspell": {
        "files": [
            "*/*.*"
        ],
        "import": [
            "@taiga-ui/cspell-config/cspell.config.js"
        ]
    },
    "release-it": {
        "extends": "./projects/release-it-config/.release-it.js"
    },
    "syncer": {
        "includePaths": [
            "./projects",
            "./package-lock.json"
        ],
        "matchPackageNames": [
            "@taiga-ui/*"
        ]
    }
}
